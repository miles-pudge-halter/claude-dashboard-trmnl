<!--
  Claude Code Dashboard — Terminus full layout, codex-bar inspired.

  Layout uses the framework's `gap--space-between` on a layout--col so the
  three sections (bars / costs / activity items) distribute vertically
  across the full screen instead of clustering in the middle. The
  `layout:has(+.title_bar)` rule handles the height math relative to the
  title bar at the bottom.

  Required outer wrappers:
    {{extension.css_classes}}    binds the per-device theme variables
                                 (screen, screen--Nbit, screen--md/lg)
                                 that drive progress-bar fill colors.
    view view--full              gives the inner layout a sized box.
-->

<div class="{{extension.css_classes}}">
<div class="view view--full">

<div class="layout layout--col layout--stretch-x gap--space-between">

  <!-- ───────────── rate-limit bars ───────────── -->
  <div class="progress-bar stretch-x">
    <div class="content">
      <span class="label label--small">Session</span>
      <span class="value value--xxsmall">
        {{ source_1.session_pct_left }}% left · resets in {{ source_1.session_eta }}
      </span>
    </div>
    <div class="track">
      <div class="fill" style="width:{{ source_1.session_pct }}%"></div>
      <div class="fill" style="width:2px;left:{{ source_1.session_pace_pct }}%;background:#000;"></div>
    </div>
  </div>

  <div class="progress-bar stretch-x">
    <div class="content">
      <span class="label label--small">Weekly</span>
      <span class="value value--xxsmall">
        {{ source_1.week_all_pct_left }}% left{% if source_1.week_all_reserve_pct != "0" %} · {{ source_1.week_all_reserve_pct }}% reserve{% endif %} · resets in {{ source_1.week_all_eta }}
      </span>
    </div>
    <div class="track">
      <div class="fill" style="width:{{ source_1.week_all_pct }}%"></div>
      <div class="fill" style="width:2px;left:{{ source_1.week_all_pace_pct }}%;background:#000;"></div>
    </div>
  </div>

  <!-- ───────────── cost / efficiency hero ───────────── -->
  <div class="grid grid--cols-2 gap--xlarge">

    <div class="flex flex--col flex--stretch-x">
      <span class="label label--small">Today</span>
      <span class="value value--large">${{ source_1.today_cost }}</span>
      <span class="value value--xxsmall">
        {{ source_1.today_tokens }} tokens · {{ source_1.today_msgs }} msgs
      </span>
      <span class="value value--xxsmall">
        {{ source_1.cache_pct }}% cache · ${{ source_1.cache_savings }} saved
      </span>
    </div>

    <div class="flex flex--col flex--stretch-x">
      <span class="label label--small">Last 30 days</span>
      <span class="value value--large">${{ source_1.last_30d_cost }}</span>
      <span class="value value--xxsmall">
        {{ source_1.last_30d_tokens }} tokens · {{ source_1.last_30d_msgs }} msgs
      </span>
      <span class="value value--xxsmall">
        ${{ source_1.last_30d_avg }}/day avg · {{ source_1.last_30d_active_days }} active days
      </span>
    </div>

  </div>

  <!-- ───────────── activity items ───────────── -->
  <div class="grid grid--cols-6">

    <div class="flex flex--col flex--stretch-x">
      <span class="value value--medium">{{ source_1.active_now }}</span>
      <span class="label label--small">Running</span>
    </div>

    <div class="flex flex--col flex--stretch-x">
      <span class="value value--medium">{{ source_1.sessions_today }}</span>
      <span class="label label--small">Today</span>
    </div>

    <div class="flex flex--col flex--stretch-x">
      <span class="value value--medium">{{ source_1.week_sessions }}</span>
      <span class="label label--small">Week</span>
    </div>

    <div class="flex flex--col flex--stretch-x">
      <span class="value value--medium">{{ source_1.all_sessions }}</span>
      <span class="label label--small">Total</span>
    </div>

    <div class="flex flex--col flex--stretch-x">
      <span class="value value--medium">{{ source_1.streak }}d</span>
      <span class="label label--small">Streak</span>
    </div>

    <div class="flex flex--col flex--stretch-x">
      <span class="value value--medium">{{ source_1.hours_today }}</span>
      <span class="label label--small">Coded</span>
    </div>

  </div>

</div><!-- layout layout--col gap--space-between -->

<div class="title_bar">
  <span class="title">
    Claude · {{ source_1.plugin_count }} plugins · {{ source_1.mcp_count }} MCPs · {{ source_1.primary_model }} {{ source_1.primary_pct }}%{% if source_1.machines and source_1.machines != "1" %} · {{ source_1.machines }} machines{% endif %}
  </span>
  <span class="instance">{{ source_1.updated_at }}</span>
</div>

</div><!-- view view--full -->
</div><!-- screen / extension.css_classes -->
